            <button key={v} className={`nav-btn${view === v ? " active" : ""}`} onClick={() => setView(v)}>{v}</button>
          ))}
        </nav>
        {showCatStrip && (
          <div className="cat-strip">
            {CATEGORIES.map(c => (
              <button key={c} className={`cat-btn${cat === c ? " active" : ""}`} onClick={() => setCat(c)}>
                <span>{CAT_ICONS[c]}</span>{c}
