  .nav-btn { background: none; border: none; color: #a09070; font-family: var(--sans); font-size: 12px;
    font-weight: 500; letter-spacing: .06em; text-transform: uppercase; padding: 14px 10px;
    cursor: pointer; transition: color .15s; white-space: nowrap; border-bottom: 2px solid transparent; }
  .nav-btn:hover { color: var(--warm); }
  .nav-btn.active { color: var(--warm); border-bottom-color: var(--ember); }

  /* Category strip */
  .cat-strip { background: var(--pale); border-bottom: 1px solid var(--border);
    display: flex; gap: 4px; padding: 8px 12px; overflow-x: auto; scrollbar-width: none; }
  .cat-strip::-webkit-scrollbar { display: none; }
  .cat-btn { background: none; border: 1px solid var(--border); border-radius: 20px;
    font-family: var(--sans); font-size: 12px; color: var(--smoke); padding: 4px 12px;
    cursor: pointer; white-space: nowrap; transition: all .15s; display: flex; align-items: center; gap: 5px; }
  .cat-btn:hover { border-color: var(--warm); color: var(--ink); }
  .cat-btn.active { background: var(--ember); border-color: var(--ember); color: #fff; }

  .main { flex: 1; padding: 20px 16px; }

  /* Home / Welcome */
  .home { display: flex; flex-direction: column; gap: 0; }
  .home-hero { background: var(--ink); padding: 36px 24px 28px; text-align: center;
