// ── Helpers ─────────────────────────────────────────────────────────────────
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function useFiltered(cat) {
  return useMemo(() => cat === "All" ? VOCAB : VOCAB.filter(e => e.c === cat), [cat]);
}

// Pick a random entry for the home tip
function randomEntry() {
  const good = VOCAB.filter(e => e.e.length > 20 && e.p.length > 2 && e.p.length < 20);
  return good[Math.floor(Math.random() * good.length)];
}

