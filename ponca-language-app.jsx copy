// ── Flashcards ────────────────────────────────────────────────────────────────
function Flashcards({ entries }) {
  const [deck, setDeck]   = useState(() => shuffle(entries));
  const [idx, setIdx]     = useState(0);
  const [flipped, setFlipped] = useState(false);

  useEffect(() => { setDeck(shuffle(entries)); setIdx(0); setFlipped(false); }, [entries]);

  if (!entries.length) return <div className="empty"><div className="empty-icon">◈</div><p>No entries in this category.</p></div>;

  const entry = deck[idx % deck.length];
  const total = deck.length;

  return (
    <div className="flashcard-wrap">
      <div className="card-counter">{idx + 1} / {total}</div>
      <div className="card" onClick={() => setFlipped(f => !f)}>
        <span className="card-cat-badge">{CAT_ICONS[entry.c]} {entry.c}</span>
        {!flipped ? (
          <>
            <div className="card-ponca">{entry.p}</div>
            <div className="card-phonetic">/{entry.ph}/</div>
            {entry.t && <div className="card-pos">{entry.t}</div>}
            <div className="card-divider" />
            <div className="card-hint">tap to reveal</div>
          </>
        ) : (
          <>
            <div className="card-ponca">{entry.p}</div>
            <div className="card-phonetic">/{entry.ph}/</div>
            <div className="card-divider" />
            <div className="card-english">{entry.e}</div>
          </>
        )}
      </div>
      <div className="card-nav">
        <button className="card-nav-btn secondary" onClick={() => { setIdx(i => Math.max(0, i-1)); setFlipped(false); }}>← Prev</button>
        <button className="shuffle-btn" onClick={() => { setDeck(shuffle(entries)); setIdx(0); setFlipped(false); }}>⇄</button>
        <button className="card-nav-btn" onClick={() => { setIdx(i => Math.min(total-1, i+1)); setFlipped(false); }}>Next →</button>
      </div>
    </div>
  );
}

// ── Quiz ──────────────────────────────────────────────────────────────────────
function Quiz({ entries }) {
  const [mode, setMode]   = useState("ponca");
  const [deck, setDeck]   = useState([]);
  const [qIdx, setQIdx]   = useState(0);
  const [chosen, setChosen] = useState(null);
  const [score, setScore] = useState({ correct: 0, total: 0 });

  const initDeck = useCallback((ents) => {
    if (ents.length < 4) return;
    setDeck(shuffle(ents));
    setQIdx(0);
    setChosen(null);
    setScore({ correct: 0, total: 0 });
  }, []);

  useEffect(() => { initDeck(entries); }, [entries, initDeck]);

  if (entries.length < 4) {
    return (
      <div className="quiz-insufficient">
        <div style={{ fontSize: 32, marginBottom: 10 }}>◎</div>
        <p>Need at least 4 entries for a quiz.</p>
        <p style={{ fontSize: 13, marginTop: 6 }}>Try selecting "All" or a larger category.</p>
      </div>
    );
  }
  if (!deck.length) return null;

  const q = deck[qIdx];
  if (!q) return null;

  // Build options without hooks in render — derive them from deck+qIdx deterministically
  const otherEntries = entries.filter(e => e.id !== q.id);
  const wrongPool = shuffle(otherEntries).slice(0, 3);
  const opts = shuffle([q, ...wrongPool]);

  const answer = (opt) => {
    if (chosen !== null) return;
    setChosen(opt.id);
    setScore(s => ({ correct: s.correct + (opt.id === q.id ? 1 : 0), total: s.total + 1 }));
  };

  const next = () => {
    if (qIdx + 1 >= deck.length) {
      initDeck(entries);
    } else {
      setQIdx(i => i + 1);
      setChosen(null);
    }
  };

  const pct = Math.round((qIdx / deck.length) * 100);
  const shortDef = (e) => e.e.split(/[,;]/)[0].trim().slice(0, 60);

  return (
    <div className="quiz-wrap">
      <div className="quiz-score">
        <span>Score: {score.correct}/{score.total}</span>
        <span>{qIdx + 1}/{deck.length}</span>
      </div>
      <div className="quiz-progress"><div className="quiz-progress-fill" style={{ width: pct + "%" }} /></div>
      <div className="quiz-q">
        <div className="quiz-q-label">{mode === "ponca" ? "What does this mean?" : "How do you say…"}</div>
        {mode === "ponca"
          ? <><div className="quiz-q-text">{q.p}</div><div className="quiz-q-sub">/{q.ph}/</div></>
          : <div className="quiz-q-text" style={{ fontFamily:"var(--sans)", fontSize:20 }}>{shortDef(q)}</div>
        }
      </div>
      <div className="quiz-opts">
        {opts.map(opt => {
          let cls = "quiz-opt";
          if (chosen !== null) {
            if (opt.id === q.id) cls += " correct";
            else if (opt.id === chosen) cls += " wrong";
            else cls += " reveal";
          }
          return (
            <button key={opt.id} className={cls} disabled={chosen !== null} onClick={() => answer(opt)}>
              {mode === "ponca"
                ? shortDef(opt)
                : <><span style={{fontFamily:"var(--serif)",fontWeight:700}}>{opt.p}</span><br/>
                    <span style={{fontSize:12,color:"var(--smoke)",fontStyle:"italic"}}>/{opt.ph}/</span></>
              }
            </button>
          );
        })}
      </div>
      {chosen !== null && (
        <div style={{ textAlign:"center" }}>
          <div style={{ fontSize:13, fontWeight:500, marginBottom:12,
            color: chosen === q.id ? "#5a9a44" : "#c05040" }}>
            {chosen === q.id ? "✓ Correct!" : `✗  ${mode === "ponca" ? shortDef(q) : q.p}`}
          </div>
          <button className="card-nav-btn" onClick={next}>Next →</button>
        </div>
      )}
      <div style={{ display:"flex", justifyContent:"center", gap:8, marginTop:4 }}>
        <button className="shuffle-btn" style={{fontSize:12}}
          onClick={() => { setMode(m => m === "ponca" ? "english" : "ponca"); initDeck(entries); }}>
          ⇄ Switch direction
        </button>
        <button className="shuffle-btn" style={{fontSize:12}} onClick={() => initDeck(entries)}>↺ New round</button>
      </div>
    </div>
  );
}

// ── Search ────────────────────────────────────────────────────────────────────
function Search() {
  const [q, setQ] = useState("");
  const results = useMemo(() => {
    const s = q.trim().toLowerCase();
    if (s.length < 2) return [];
    return VOCAB.filter(e =>
      e.p.toLowerCase().includes(s) || e.e.toLowerCase().includes(s) || e.ph.toLowerCase().includes(s)
    ).slice(0, 80);
  }, [q]);

  return (
    <div>
      <div className="search-box">
        <span className="search-icon">⊕</span>
        <input className="search-input" placeholder="Search Ponca or English…" value={q}
          onChange={e => setQ(e.target.value)} autoFocus />
      </div>
      {q.trim().length < 2
        ? <div className="search-empty">Type at least 2 characters<br/><span style={{fontSize:12}}>Searches Ponca words, English, and phonetics</span></div>
        : results.length === 0
          ? <div className="search-empty">No results for "{q}"</div>
          : <>
              <div style={{fontSize:12,color:"var(--smoke)",marginBottom:8}}>{results.length} result{results.length !== 1 ? "s" : ""}</div>
              {results.map(e => (
                <div key={e.id} className="result-card">
                  <div className="result-ponca">{e.p}</div>
                  <div className="result-badge">{CAT_ICONS[e.c]} {e.c}</div>
                  <div className="result-phonetic">/{e.ph}/  {e.t && `· ${e.t}`}</div>
                  <div className="result-english">{e.e}</div>
                </div>
              ))}
            </>
      }
    </div>
  );
}

// ── Browse ────────────────────────────────────────────────────────────────────
function Browse({ entries }) {
  const grouped = useMemo(() => {
    const sorted = [...entries].sort((a, b) => a.p.localeCompare(b.p, "en", { sensitivity: "base" }));
    const out = {};
    for (const e of sorted) {
      const letter = (e.p[0] || "?").toUpperCase();
      if (!out[letter]) out[letter] = [];
      out[letter].push(e);
    }
    return out;
  }, [entries]);

  if (!entries.length) return <div className="empty"><div className="empty-icon">◈</div><p>No entries.</p></div>;

  return (
    <div>
      <div style={{fontSize:12,color:"var(--smoke)",marginBottom:12}}>{entries.length.toLocaleString()} entries</div>
      {Object.entries(grouped).map(([letter, items]) => (
        <div key={letter}>
          <div className="browse-letter">{letter}</div>
          {items.map(e => (
            <div key={e.id} className="browse-item">
              <div className="browse-ponca">{e.p}</div>
              <div className="browse-cat">{CAT_ICONS[e.c]} {e.c}</div>
              <div className="browse-ph">/{e.ph}/  {e.t && `· ${e.t}`}</div>
              <div className="browse-def">{e.e}</div>
            </div>
          ))}
        </div>
      ))}
    </div>
  );
}

// ── About ─────────────────────────────────────────────────────────────────────
function About() {
  const cats = useMemo(() => {
    const c = {};
    for (const e of VOCAB) c[e.c] = (c[e.c] || 0) + 1;
    return Object.entries(c).sort((a,b) => b[1]-a[1]);
  }, []);

  return (
    <div className="about">
      <h2>Dictionary of the Ponca People</h2>
      <p>This app is built from <em>Dictionary of the Ponca People</em> by Louis Headman and Sean O'Neill (University of Nebraska Press, 2019), covering the Southern Ponca dialect of north-central Oklahoma.</p>
      <div className="about-stats">
        <div className="about-stat"><span className="about-stat-n">{VOCAB.length.toLocaleString()}</span><span className="about-stat-l">entries</span></div>
        <div className="about-stat"><span className="about-stat-n">{cats.length}</span><span className="about-stat-l">categories</span></div>
        <div className="about-stat"><span className="about-stat-n">169</span><span className="about-stat-l">source pages</span></div>
      </div>
      <h3>Reading the phonetics</h3>
      <p>Vowels with accent marks (á, à) indicate tone. Hook letters (ą, į, ų) are nasalized vowels. <em>š, ž, č</em> represent sh/zh/ch sounds. <em>ʼ</em> marks a glottal stop. Superscript <em>ⁿ</em> nasalizes the preceding vowel.</p>
      <h3>Categories</h3>
      {cats.map(([cat, n]) => (
        <div key={cat} style={{display:"flex",justifyContent:"space-between",padding:"5px 0",
          borderBottom:"1px solid var(--pale)",fontSize:14}}>
          <span>{CAT_ICONS[cat]} {cat}</span>
          <span style={{color:"var(--smoke)"}}>{n}</span>
        </div>
      ))}
      <h3>About the Ponca Nation</h3>
      <p>The Ponca are a Siouan-speaking people originally from the Niobrara River region of present-day Nebraska. After the forced removal of 1877, the Southern Ponca settled in north-central Oklahoma. The language belongs to the Dhegiha branch of the Siouan family, closely related to Omaha.</p>
      <p style={{marginTop:16,fontSize:12,color:"var(--border)"}}>Vocabulary extracted from the source EPUB for educational purposes.</p>
    </div>
  );
}

